cff-version: 1.2.0
message: "If you use this dataset, please cite it using the metadata below."
type: dataset
title: "respublica-gpt: A Demographically Diverse Synthetic Image Dataset for Deepfake Detection Research"
authors:
  - name: "RespublicaData"
version: "1.0.0"
date-released: "2026-05-06"
url: "https://github.com/RespublicaData/respublica-gpt"
repository-code: "https://github.com/RespublicaData/respublica-gpt"
license: "LicenseRef-research-only"
abstract: >
  respublica-gpt is a dataset of 2,797 AI-generated images built for deepfake
  detection research using OpenAI's gpt-image-2 model (April 2026). Every image
  is paired with full structured metadata across 11 detection-relevant axes
  including demographics, camera style, lighting, artifacts, and platform
  degradation. The dataset prioritizes demographic diversity and Global Majority
  representation to address documented detector bias against non-Western faces.
keywords:
  - deepfake detection
  - synthetic media
  - AI-generated images
  - dataset
  - fairness
  - TRIED benchmark
  - gpt-image-2
references:
  - type: article
    title: "TRIED: Truly Innovative and Effective AI Detection Benchmark"
    authors:
      - family-names: anlen
        given-names: shirin
      - family-names: Wojciak
        given-names: Zuzanna
    journal: "arXiv preprint arXiv:2504.21489"
    year: 2025
    url: "https://arxiv.org/abs/2504.21489"
